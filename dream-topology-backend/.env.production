# Environment configuration
NODE_ENV=production
PORT=3000

# Database
DATABASE_URL="file:/var/data/dream_topology_prod.db"

# OpenAI API (or compatible API like DeepSeek)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com/v1

# Zhipu AI
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Security
# MUST change in production!
JWT_SECRET=generate_a_secure_random_string_here
ENCRYPTION_KEY=generate_a_secure_32_byte_string_for_aes256

# CORS
FRONTEND_ORIGIN=https://www.hyxhhh.site
CORS_ORIGINS=https://www.hyxhhh.site,https://hyxhhh.site
